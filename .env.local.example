# ================================================================
#  fuu ふぅ  環境変数テンプレート
#  このファイルを .env.local にコピーして値を埋めてください
#  $ cp .env.local.example .env.local
# ================================================================

# ── Supabase ────────────────────────────────────────────────────
# Supabase Dashboard > Project Settings > API から取得
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# ※ SERVICE_ROLE_KEY は絶対に公開しないこと（Webhook/Edge Functions専用）

# ── Anthropic（Claude Haiku）────────────────────────────────────
# https://console.anthropic.com/api-keys から取得
ANTHROPIC_API_KEY=sk-ant-

# ── Stripe ──────────────────────────────────────────────────────
# https://dashboard.stripe.com/apikeys から取得
STRIPE_SECRET_KEY=sk_test_...        # 本番は sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...      # Stripe CLI: stripe listen --forward-to localhost:3000/api/webhook/stripe

# Stripe 価格ID（Stripe Dashboard > Products で作成後に取得）
STRIPE_PRICE_STANDARD=price_...      # ¥100/月 スタンダードプラン
STRIPE_PRICE_PREMIUM=price_...       # ¥980/月 プレミアムプラン
STRIPE_PRICE_TICKET=price_...        # ¥300 チケット（one-time）

# ── OpenAI（プレミアム音声通話用）──────────────────────────────
# https://platform.openai.com/api-keys から取得
# ※ プレミアム音声機能はフェーズ2で実装
OPENAI_API_KEY=sk-...

# ── アプリ設定 ──────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000   # 本番: https://fuu-app.jp
NEXT_PUBLIC_APP_NAME=fuu ふぅ
